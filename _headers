# Cloudflare Pages cache control + charset headers
# Generated by build_site.py

# HTML — short cache so updates are picked up quickly
/*.html
  Cache-Control: public, max-age=3600, must-revalidate
  Content-Type: text/html; charset=utf-8

/
  Cache-Control: public, max-age=3600, must-revalidate
  Content-Type: text/html; charset=utf-8

# Search index — moderate cache
/search_index.json
  Cache-Control: public, max-age=3600, must-revalidate

# Images — long cache (content-addressed filenames)
/playlists/*/img/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS — moderate cache
/style.css
  Cache-Control: public, max-age=86400, must-revalidate
